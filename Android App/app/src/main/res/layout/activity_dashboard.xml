<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d1117"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VAULT COMMAND CENTER"
            android:textColor="#58a6ff"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tvHeartbeat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="● SYSTEM ONLINE"
            android:textColor="#3fb950"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp"/>

        <!-- Status card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#161b22"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VAULT STATUS"
                    android:textColor="#8b949e"
                    android:textSize="9sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="6dp"/>
                <TextView
                    android:id="@+id/tvVaultStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOADING…"
                    android:textColor="#3fb950"
                    android:textSize="26sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Auth + Active User side-by-side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="#161b22"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:layout_marginEnd="5dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AUTH"
                        android:textColor="#8b949e"
                        android:textSize="9sp"
                        android:letterSpacing="0.12"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="5dp"/>
                    <TextView
                        android:id="@+id/tvAuthState"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LOCKED"
                        android:textColor="#f85149"
                        android:textSize="16sp"
                        android:fontFamily="monospace"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="#161b22"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:layout_marginStart="5dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACTIVE USER"
                        android:textColor="#8b949e"
                        android:textSize="9sp"
                        android:letterSpacing="0.12"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="5dp"/>
                    <TextView
                        android:id="@+id/tvActiveUser"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="None"
                        android:textColor="#e6edf3"
                        android:textSize="16sp"
                        android:fontFamily="monospace"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Log_Ping card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#161b22"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LAST ESP32 PING"
                    android:textColor="#8b949e"
                    android:textSize="9sp"
                    android:letterSpacing="0.12"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="5dp"/>
                <TextView
                    android:id="@+id/tvLastPing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Waiting for ESP32 ping…"
                    android:textColor="#e6edf3"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="10dp"/>
                <ProgressBar
                    android:id="@+id/progressPing"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:max="300"
                    android:progress="0"
                    android:progressTint="#3fb950"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Authorized Users card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#161b22"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="18dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="AUTHORIZED USERS"
                        android:textColor="#8b949e"
                        android:textSize="9sp"
                        android:letterSpacing="0.12"
                        android:fontFamily="monospace"/>
                    <TextView
                        android:id="@+id/tvUserCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="– users"
                        android:textColor="#58a6ff"
                        android:textSize="9sp"
                        android:fontFamily="monospace"
                        android:background="@drawable/badge_blue"
                        android:paddingStart="9dp"
                        android:paddingEnd="9dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutUserList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <TextView
                    android:id="@+id/tvUsersEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading users…"
                    android:textColor="#8b949e"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:paddingTop="6dp"
                    android:visibility="visible"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSignOut"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="SIGN OUT"
            android:textColor="#0d1117"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            app:backgroundTint="#58a6ff"
            app:cornerRadius="10dp"/>

    </LinearLayout>
</ScrollView>