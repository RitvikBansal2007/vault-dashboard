<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d1117"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="28dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="52dp"
        android:text="VAULT"
        android:textColor="#58a6ff"
        android:textSize="34sp"
        android:letterSpacing="0.3"
        android:fontFamily="monospace"
        android:textStyle="bold"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="44dp"
        android:text="COMMAND CENTER"
        android:textColor="#8b949e"
        android:textSize="11sp"
        android:letterSpacing="0.25"
        android:fontFamily="monospace"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:text="ENTER YOUR PIN"
        android:textColor="#8b949e"
        android:textSize="10sp"
        android:letterSpacing="0.15"
        android:fontFamily="monospace"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <View android:id="@+id/dot1"
            android:layout_width="14dp" android:layout_height="14dp"
            android:background="@drawable/pin_dot" android:alpha="0.25"/>
        <View android:id="@+id/dot2"
            android:layout_width="14dp" android:layout_height="14dp"
            android:background="@drawable/pin_dot" android:alpha="0.25"
            android:layout_marginStart="18dp"/>
        <View android:id="@+id/dot3"
            android:layout_width="14dp" android:layout_height="14dp"
            android:background="@drawable/pin_dot" android:alpha="0.25"
            android:layout_marginStart="18dp"/>
        <View android:id="@+id/dot4"
            android:layout_width="14dp" android:layout_height="14dp"
            android:background="@drawable/pin_dot" android:alpha="0.25"
            android:layout_marginStart="18dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="22dp"
        android:minHeight="18dp"
        android:text=""
        android:textColor="#f85149"
        android:textSize="11sp"
        android:fontFamily="monospace"/>

    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="4">

        <Button android:id="@+id/btn1" style="@style/KeypadBtn" android:text="1"/>
        <Button android:id="@+id/btn2" style="@style/KeypadBtn" android:text="2"/>
        <Button android:id="@+id/btn3" style="@style/KeypadBtn" android:text="3"/>
        <Button android:id="@+id/btn4" style="@style/KeypadBtn" android:text="4"/>
        <Button android:id="@+id/btn5" style="@style/KeypadBtn" android:text="5"/>
        <Button android:id="@+id/btn6" style="@style/KeypadBtn" android:text="6"/>
        <Button android:id="@+id/btn7" style="@style/KeypadBtn" android:text="7"/>
        <Button android:id="@+id/btn8" style="@style/KeypadBtn" android:text="8"/>
        <Button android:id="@+id/btn9" style="@style/KeypadBtn" android:text="9"/>
        <Button android:id="@+id/btnClr" style="@style/KeypadBtnAlt" android:text="CLR"/>
        <Button android:id="@+id/btn0"   style="@style/KeypadBtn"    android:text="0"/>
        <Button android:id="@+id/btnDel" style="@style/KeypadBtnAlt" android:text="⌫"/>
    </GridLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:text="secured with SHA-256"
        android:textColor="#30363d"
        android:textSize="10sp"
        android:fontFamily="monospace"/>

</LinearLayout>