<resources>
    <style name="Theme.VaultCommandCenter"
        parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#58a6ff</item>
        <item name="colorPrimaryVariant">#1f6feb</item>
        <item name="colorOnPrimary">#0d1117</item>
        <item name="colorSurface">#161b22</item>
        <item name="colorOnSurface">#e6edf3</item>
        <item name="android:windowBackground">#0d1117</item>
        <item name="android:statusBarColor">#0d1117</item>
        <item name="android:navigationBarColor">#0d1117</item>
    </style>

    <style name="KeypadBtn" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">76dp</item>
        <item name="android:layout_height">68dp</item>
        <item name="android:layout_margin">5dp</item>
        <item name="backgroundTint">#161b22</item>
        <item name="android:textColor">#e6edf3</item>
        <item name="android:textSize">20sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">10dp</item>
    </style>

    <style name="KeypadBtnAlt" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">76dp</item>
        <item name="android:layout_height">68dp</item>
        <item name="android:layout_margin">5dp</item>
        <item name="backgroundTint">#1a1f26</item>
        <item name="android:textColor">#58a6ff</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="cornerRadius">10dp</item>
